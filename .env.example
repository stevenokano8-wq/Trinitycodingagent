# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB CONFIGURATION (Optional - for pushing project to GitHub)
GITHUB_TOKEN=""
GITHUB_REPO_URL=""

# DATABASE_URL: Postgres connection string. Optional locally (falls back to
# an in-memory store for the session). In production this is provided via a
# Cloudflare Hyperdrive binding instead of a plain env var — see wrangler.api.toml.
DATABASE_URL=""

# Upstash Redis REST credentials (fetch-based, replaces the old ioredis/TCP
# setup so this also works inside Cloudflare Workers). Optional locally
# (falls back to an in-memory cache for the session).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

