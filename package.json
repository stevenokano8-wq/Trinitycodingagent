{
  "name": "sovereign-agent",
  "version": "1.0.0",
  "description": "Sovereign Agent — AI coding agent platform",
  "main": "index.html",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "deploy": "vite build && wrangler deploy --config wrangler.toml && wrangler deploy --config wrangler.api.toml"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.3.28",
    "lucide-react": "^0.447.0",
    "hono": "^4.6.5",
    "express": "^4.21.2",
    "@google/genai": "^0.7.0",
    "motion": "^11.11.17",
    "@cloudflare/agents": "^0.0.16",
    "@cloudflare/sandbox": "^0.12.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^4.12.0"
  },
  "type": "module",
  "overrides": {
    "express": {
      "path-to-regexp": "0.1.7"
    }
  }
}
